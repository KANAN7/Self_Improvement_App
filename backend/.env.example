# Copy to .env and fill in values. Never commit .env.
# Get an Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model selection per environment. Default to Haiku for cheap dev.
INWARD_DEV_MODEL=claude-haiku-4-5-20251001
INWARD_PROD_MODEL=claude-sonnet-4

# Server
PORT=3000
NODE_ENV=development

# Per-device daily call cap (safety against bugs/abuse)
RATE_LIMIT_PER_DEVICE_PER_DAY=200
